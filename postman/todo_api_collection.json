        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"This task does not exist\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/tasks/99999",
          "host": ["{{base_url}}"],
          "path": ["tasks", "99999"]
        },
        "description": "Attempt to update a task with an ID that does not exist. Should return 404 with an error message."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 404', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('Response has error field', function () {",
              "    const body = pm.response.json();",
              "    pm.expect(body).to.have.property('error');",
              "});",
              "",
              "pm.test('Error message is correct', function () {",
              "    const body = pm.response.json();",
